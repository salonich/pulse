FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /bin/operator ./cmd/operator

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /bin/operator /operator
USER 65534:65534
ENTRYPOINT ["/operator"]
